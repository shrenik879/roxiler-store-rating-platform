# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
# NODE_ENV         : "production" on Render, "development" locally
# PORT             : Render injects this automatically (usually 10000).
#                    Set to 5000 for local dev. DO NOT hardcode in code.
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────────────────────
# Database
#   DB_DIALECT=sqlite -> zero-config, file path set by DB_STORAGE
#   DB_DIALECT=mysql  -> uses the DB_* values below
# ─────────────────────────────────────────────────────────────
# DB_STORAGE  : Absolute path to the SQLite file.
#               On Render, set this to /app/data/data.sqlite so
#               it lands on the Persistent Disk (mounted at /app/data).
#               Locally it defaults to <project>/backend/data.sqlite.
DB_DIALECT=sqlite
DB_STORAGE=/app/data/data.sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=store_rating_db
DB_USER=root
DB_PASSWORD=root123

# ─────────────────────────────────────────────────────────────
# Redis (optional)
#   Set REDIS_ENABLED=false to disable. The app degrades gracefully
#   to direct DB queries when Redis is unreachable or disabled.
#   Leave disabled on Render free tier — no Redis service needed.
# ─────────────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL_SECONDS=60

# ─────────────────────────────────────────────────────────────
# Auth / JWT
#   REQUIRED on Render. Generate secrets with:
#     openssl rand -hex 32
#   Use different secrets for ACCESS and REFRESH tokens.
#   Minimum length: 10 characters (enforced by Joi schema).
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ─────────────────────────────────────────────────────────────
# CORS
#   Comma-separated list of allowed origins.
#   On Render: set this to your deployed frontend URL, e.g.
#     CORS_ORIGIN=https://store-rating-frontend.onrender.com
#   Locally: Vite dev server runs on 5173.
# ─────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Cookies
#   COOKIE_SECURE=true  -> required in production (Render uses HTTPS)
#   COOKIE_SECURE=false -> for local HTTP development
# ─────────────────────────────────────────────────────────────
COOKIE_SECURE=false

# ─────────────────────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ─────────────────────────────────────────────────────────────
# Seeding
#   SEED_DEMO=false -> production default (only creates admin account)
#   SEED_DEMO=true  -> also seeds demo stores, owners, users, ratings
#                      Useful for a hiring/evaluation demo.
# ─────────────────────────────────────────────────────────────
SEED_DEMO=false

# ─────────────────────────────────────────────────────────────
# Default admin account (seeded on every startup via seed.js)
#   Change ADMIN_PASSWORD to a strong password on Render.
# ─────────────────────────────────────────────────────────────
ADMIN_NAME=System Administrator Account
ADMIN_EMAIL=admin@storerating.com
ADMIN_PASSWORD=Admin@1234
ADMIN_ADDRESS=Head Office, Admin Street, City
