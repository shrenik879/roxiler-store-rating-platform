# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────────────────────
# Database
#   DB_DIALECT=sqlite -> zero-config, file at backend/data.sqlite (default)
#   DB_DIALECT=mysql  -> uses the DB_* values below (docker-compose provides this)
# ─────────────────────────────────────────────────────────────
DB_DIALECT=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=store_rating_db
DB_USER=root
DB_PASSWORD=root123

# ─────────────────────────────────────────────────────────────
# Redis (optional). If disabled or unreachable, caching degrades to direct DB.
# ─────────────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL_SECONDS=60

# ─────────────────────────────────────────────────────────────
# Auth / JWT  (use long random strings in production)
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ─────────────────────────────────────────────────────────────
# CORS (comma-separated origins). Vite dev server runs on 5173.
# ─────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ─────────────────────────────────────────────────────────────
# Default admin (seeded on first run if absent)
# ─────────────────────────────────────────────────────────────
ADMIN_NAME=Rajesh Kumar Choudhary
ADMIN_EMAIL=admin@storerating.com
ADMIN_PASSWORD=Admin@1234
ADMIN_ADDRESS=Head Office, Admin Street, City
